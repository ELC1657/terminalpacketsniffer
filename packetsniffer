#!/usr/bin/env bash
# Packet Sniffer — auto-setup + launcher
# Usage: packetsniffer [-i INTERFACE] [-p PROTOCOL] [--host IP] [--port PORT]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Guard: if SCRIPT_DIR resolved incorrectly (e.g. BASH_SOURCE unset in some
# sudo contexts), fail fast with a clear message instead of silently using the
# wrong Python and script path.
if [ ! -f "$SCRIPT_DIR/sniffer_tui.py" ]; then
    echo "Error: packetsniffer could not locate the project files."
    echo "Re-run the installer from the project directory:"
    echo "  cd /path/to/packet-sniffer && sudo ./install"
    exit 1
fi

VENV="$SCRIPT_DIR/venv"
PYTHON="$VENV/bin/python"
PIP="$VENV/bin/pip"
STAMP="$VENV/.installed"

# ── 1. create venv if missing ─────────────────────────────────────────────────
if [ ! -f "$PYTHON" ]; then
    echo "[setup] creating virtual environment..."
    python3 -m venv "$VENV"
fi

# ── 2. install deps if requirements changed ───────────────────────────────────
if [ ! -f "$STAMP" ] || [ "$SCRIPT_DIR/requirements.txt" -nt "$STAMP" ]; then
    echo "[setup] installing dependencies..."
    "$PIP" install -q -r "$SCRIPT_DIR/requirements.txt"
    touch "$STAMP"
fi

# ── 3. select script (--cli flag chooses the plain terminal sniffer) ─────────
SCRIPT="$SCRIPT_DIR/sniffer_tui.py"
if [[ "${1:-}" == "--cli" ]]; then
    SCRIPT="$SCRIPT_DIR/sniffer.py"
    shift
fi

# ── 4. run (re-exec with sudo if needed for raw packet capture) ───────────────
if [ "$EUID" -ne 0 ]; then
    exec sudo "$PYTHON" "$SCRIPT" "$@"
else
    exec "$PYTHON" "$SCRIPT" "$@"
fi
